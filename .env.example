NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Note:
# Use only public browser-safe Supabase keys here.
# During Supabase's key transition, a legacy anon key value can be placed in NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY if your project dashboard still shows anon key naming.
# Never put service_role or secret keys in this file.

# Local development only. Leave disabled unless you need a real Supabase session for local browser testing.
ENABLE_DEV_LOGIN=false
DEV_LOGIN_EMAIL=
DEV_LOGIN_PASSWORD=
